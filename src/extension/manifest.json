{
  "manifest_version": 3,
  "name": "web-mcp extension",
  "version": "1.0.0",
  "description": "An advanced in-browser automation copilot that gives AI assistants direct control over Chrome with real-time visual feedback.",
  "icons": {
    "128": "icon128.png"
  },
  "permissions": [
    "sidePanel",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "service_worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["env.js", "content.js"],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["sidepanel.html"],
      "matches": ["<all_urls>"]
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "web-mcp",
    "default_icon": {
      "128": "icon128.png"
    }
  }
}
